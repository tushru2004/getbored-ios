{
  "manifest_version": 3,
  "name": "GetBored Child Registration",
  "description": "Spike extension that proves Safari page context can reach the GetBored App Group.",
  "version": "0.1",
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png",
    "256": "icon-256.png",
    "512": "icon-512.png"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "permissions": ["nativeMessaging"],
  "host_permissions": ["<all_urls>"]
}
